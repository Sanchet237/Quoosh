# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/quoosh"

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="your-secret-here"
NEXTAUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"

# ─── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
WEB_ORIGIN="http://localhost:3000"

# ─── Socket ───────────────────────────────────────────────────────────────────
SOCKET_PORT="3001"
SOCKET_URL="http://localhost:3001"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# ─── Admin Socket ─────────────────────────────────────────────────────────────
# REQUIRED — Admin socket namespace secret. Must be at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️  NEVER use a short or default value in production — change this before deploying
# Must match NEXT_PUBLIC_ADMIN_SOCKET_SECRET (used by the browser to connect to /admin)
ADMIN_SOCKET_SECRET=
NEXT_PUBLIC_ADMIN_SOCKET_SECRET=

# Email address that receives contact form submissions (Resend)
CONTACT_EMAIL=you@yourdomain.com

# ============================================================
# RATE LIMITING — Required for production security
# Without these, login and register have no brute-force protection
# Get free credentials at https://upstash.com
# ============================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Docker only — PostgreSQL password for the db container (docker-compose.yml)
DB_PASSWORD=